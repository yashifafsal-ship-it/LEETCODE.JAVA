class Solution {
    public boolean isPalindrome(int x) {
        //negative number are never palindrome (the minus sign breaks aymmetry)
        if (x<0) {
            return false;

        }

        int original = x;
        int reversed = 0;

        while (x !=0) {
            int digit = x % 10;
            x = x / 10;
            reversed = reversed * 10 + digit;
    
        }

        return original == reversed;
    }
